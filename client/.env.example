# Client Environment Variables
# Copy this file to .env.local and fill in your values.
# See docs/ENVIRONMENT.md for the canonical variable matrix.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Backend API
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
API_SECRET_KEY=your_api_secret_key_here

# App Runtime
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development
NODE_ENV=development
LOG_LEVEL=info
MAINTENANCE_MODE=false
ANALYTICS_ID=

# Authentication / Encryption
JWT_SECRET=your_jwt_secret_key_here
ENCRYPTION_KEY=your_32_byte_encryption_key

# Stripe / Payments
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_TEST_SECRET_KEY=sk_test_...
STRIPE_LIVE_SECRET_KEY=sk_live_...
PAYSTACK_SECRET_KEY=sk_test_...
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id
ENABLE_MOCK_PAYMENTS=false

# Monitoring
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Blockchain / Stellar
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# Push Notifications
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REDIS_URL=redis://localhost:6379
RATE_LIMIT_IMPORT_MAX=10
RATE_LIMIT_IMPORT_WINDOW_MINUTES=15
RATE_LIMIT_PAYMENT_MAX=20
RATE_LIMIT_PAYMENT_WINDOW_MINUTES=15
RATE_LIMIT_TAG_MUTATION_MAX=60
RATE_LIMIT_TAG_MUTATION_WINDOW_MINUTES=15
